/* 
template that creates the list of files created the exact date (made for daily notes so it imports the date from the title) and counts them
Dataview plugin is obligatory
*/

```dataviewjs
let currentDay = dv.current().file.day; 

if (currentDay) { 
	let count = dv.pages() .where(p => p.date && p.date.ts === currentDay.ts) .length; 
	dv.paragraph("Files created that day: **" + count + "**"); } 

```
```dataview
LIST WHERE date = this.file.day
```


